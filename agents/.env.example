# SoloQuest Agent Backend Environment Variables

# SoloQuest API (Next.js backend)
SOLOQUEST_API_URL=http://localhost:3000
SOLOQUEST_API_TOKEN=

# Kimi / Moonshot API (OpenAI-compatible — fast/cheap agent tasks)
# Sign up: https://platform.moonshot.cn → API Keys
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=moonshot-v1-8k

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Notion Integration (optional)
NOTION_API_KEY=
NOTION_DATABASE_ID=
