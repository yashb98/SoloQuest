# SoloQuest Agent Backend Environment Variables

# SoloQuest API (Next.js backend)
SOLOQUEST_API_URL=http://localhost:3000
SOLOQUEST_API_TOKEN=

# Kimi Code API (OpenAI-compatible)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.ai/v1
KIMI_MODEL=kimi

# Anthropic Claude API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Langfuse Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Notion Integration (optional)
NOTION_API_KEY=
NOTION_DATABASE_ID=
