# ============================================
# SoloQuest — Web App (.env in apps/web/)
# ============================================

# --- AI Providers ---
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=

# --- Database ---
DATABASE_URL=file:./dev.db

# Production (Turso — free tier: 9GB storage, 500 DBs, 25M row reads/mo)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# --- API Authentication ---
# Shared bearer token for mobile app + agent backend to call web API
# Generate one: openssl rand -hex 32
SOLOQUEST_API_TOKEN=

# ============================================
# Agent Backend (.env in agents/)
# ============================================

# SoloQuest API (Next.js backend URL)
SOLOQUEST_API_URL=http://localhost:3000
# SOLOQUEST_API_TOKEN= (same as above)

# --- Kimi Code API ---
KIMI_API_KEY=
KIMI_BASE_URL=https://api.kimi.com/coding/
KIMI_MODEL=Kimi-k2.5

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY= (same as web app)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Langfuse Observability ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Notion Integration (optional) ---
NOTION_API_KEY=
NOTION_DATABASE_ID=
