# Anthropic API Key (required for AI features: mentor, briefings, exams, quest chains)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database URL (used by Prisma CLI for migrations/push)
DATABASE_URL=file:./dev.db

# Ollama Fallback LLM (used when Anthropic API is unavailable)
# Install: brew install ollama && ollama pull mistral
# Best models: mistral (recommended), llama3.2, phi3
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Production Database (Turso) — only needed for production deployment
# TURSO_DATABASE_URL=
# TURSO_AUTH_TOKEN=
