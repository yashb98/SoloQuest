{
  "permissions": {
    "allow": [
      "Bash(cat /Users/yashbishnoi/SoloQuest/src/app/\\\\\\(app\\\\\\)/quests/page.tsx)"
    ],
    "additionalDirectories": [
      "/Users/yashbishnoi/SoloQuest/.claude"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "npx next lint --file \"$CLAUDE_FILE_PATHS\" --quiet 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"continue\": true}'"
          }
        ]
      }
    ]
  }
}
