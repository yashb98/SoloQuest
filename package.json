{
  "name": "soloquest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @soloquest/web dev",
    "build": "pnpm --filter @soloquest/web build",
    "lint": "pnpm --filter @soloquest/web lint",
    "dev:mobile": "pnpm --filter @soloquest/mobile start",
    "dev:agents": "cd agents && uvicorn src.soloquest_agents.server:app --reload",
    "db:push": "pnpm --filter @soloquest/web db:push",
    "db:seed": "pnpm --filter @soloquest/web db:seed",
    "db:studio": "pnpm --filter @soloquest/web db:studio"
  }
}
